# Local SQLite URL. Docker Compose overrides this with PostgreSQL automatically.
DATABASE_URL=file:./dev.db

# Production image deployment. docker-compose.yml pulls this image instead of building on the server.
# APP_PORT is also the host port to use when checking http://127.0.0.1:${APP_PORT}/api/health.
IMAGE_NAME=ghcr.io/pairmeng/image-2-studio
IMAGE_TAG=latest
APP_PORT=3000

# PostgreSQL password used by docker-compose.yml.
# Production deployments with the built-in PostgreSQL service must replace change-me.
# Example: POSTGRES_PASSWORD=Q7mVx9p2LrT4s8Kz
POSTGRES_PASSWORD=change-me

# Secret used to encrypt stored API keys and session-related data.
# Production deployments must replace this with at least 32 random characters before startup.
# Generate one with: openssl rand -hex 32
# Example: APP_SECRET=7f37f6f9e4e8a6f66e6f65b5c4c1d6d0b8c5e1b7a4d2f0c9a8e6f5d4c3b2a1f0
APP_SECRET=replace-with-at-least-32-random-characters

# Session cookie security.
# Keep the default true behavior for production HTTPS.
# Set AUTH_COOKIE_SECURE=false only when testing through plain HTTP, such as http://SERVER_IP:3000.
# Example for temporary HTTP testing: AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SECURE=

# Initial admin account created on first startup.
# Example: INITIAL_ADMIN_EMAIL=admin@your-domain.com
INITIAL_ADMIN_EMAIL=admin@example.com
# Example: INITIAL_ADMIN_PASSWORD=Use-A-Long-Random-Password-2026!
INITIAL_ADMIN_PASSWORD=change-this-password

# Optional platform provider settings. Admins can also configure these in the UI.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_IMAGE_MODEL=
FAL_KEY=
FAL_IMAGE_MODEL=
