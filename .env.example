# Local SQLite URL. The bundled docker-compose.yml overrides this with PostgreSQL automatically.
DATABASE_URL=file:./dev.db

# Production image deployment. docker-compose.yml pulls this image instead of building on the server.
# APP_PORT is also the host port to use when checking http://127.0.0.1:${APP_PORT}/api/health.
IMAGE_NAME=ghcr.io/paimonria/image-2-studio
IMAGE_TAG=latest
APP_PORT=3000

# Single-host scale deployment defaults used by docker-compose.scale.yml.
# Web containers are routed through the bundled Nginx proxy; worker containers consume Redis jobs.
WEB_REPLICAS=2
WORKER_REPLICAS=2

# PostgreSQL password used by docker-compose.yml.
# Production deployments with the built-in PostgreSQL service must replace change-me.
# Example: POSTGRES_PASSWORD=Q7mVx9p2LrT4s8Kz
POSTGRES_PASSWORD=change-me

# Set this to use an external PostgreSQL database in docker-compose.yml.
# Example: DOCKER_DATABASE_URL=postgresql://db_user:db_password@db_host:5432/db_name?schema=public
DOCKER_DATABASE_URL=

# Prisma PostgreSQL connection cap per app container. Lower it if you scale app containers up.
DATABASE_CONNECTION_LIMIT=5

# Prisma PostgreSQL connection cap per worker container.
WORKER_DATABASE_CONNECTION_LIMIT=5

# Prisma PostgreSQL connection cap for the one-shot migration container in scaled deployments.
MIGRATE_DATABASE_CONNECTION_LIMIT=5

# Secret used to encrypt stored API keys and session-related data.
# Production deployments must replace this with at least 32 random characters before startup.
# Generate one with: openssl rand -hex 32
# Example: APP_SECRET=7f37f6f9e4e8a6f66e6f65b5c4c1d6d0b8c5e1b7a4d2f0c9a8e6f5d4c3b2a1f0
APP_SECRET=replace-with-at-least-32-random-characters

# Session cookie security.
# Keep the default true behavior for production HTTPS.
# Set AUTH_COOKIE_SECURE=false only when testing through plain HTTP, such as http://SERVER_IP:3000.
# Example for temporary HTTP testing: AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SECURE=

# Max image generation jobs running at the same time in one app container.
# Increase only if your upstream gateway, database, network, and memory can handle it.
IMAGE_JOB_CONCURRENCY=2

# Max image generation jobs one user can occupy at the same time in one app container.
# The default is half of IMAGE_JOB_CONCURRENCY, rounded up.
IMAGE_JOB_USER_CONCURRENCY=1

# Redis queue URL.
# The bundled docker-compose.yml points at the local Redis service by default.
# Set a complete REDIS_URL here when you use an external Redis provider.
# Put authentication and TLS in this single URL; do not configure a separate Redis password.
# Use rediss:// when your Redis provider requires TLS.
# Examples:
# REDIS_URL=redis://:password@redis.example.com:6379/0
# REDIS_URL=rediss://:password@redis.example.com:6380/0
REDIS_URL=
IMAGE_QUEUE_PREFIX=image2
IMAGE_WORKER_CONCURRENCY=4
IMAGE_QUEUE_ATTEMPTS=3
IMAGE_QUEUE_BACKOFF_MS=5000

# Initial admin account created on first startup.
# Example: INITIAL_ADMIN_EMAIL=admin@your-domain.com
INITIAL_ADMIN_EMAIL=admin@example.com
# Example: INITIAL_ADMIN_PASSWORD=Use-A-Long-Random-Password-2026!
INITIAL_ADMIN_PASSWORD=change-this-password

# Optional platform provider settings. Admins can also configure these in the UI.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_IMAGE_MODEL=
