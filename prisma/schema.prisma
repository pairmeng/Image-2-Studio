generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("USER")
  disabled     Boolean  @default(false)
  jobMonitorClearedAt DateTime?
  jobMonitorFinishedClearedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions       Session[]
  providerConfig ProviderConfig?
  images         ImageRecord[]
  imageJobs      ImageJob[]
  imageBatches   ImageBatch[]
  imageBatchItems ImageBatchItem[]
  imageProjects  ImageProject[]
  promptTemplates PromptTemplate[]
  usage          UsageDaily[]
}

model Session {
  id           String   @id @default(cuid())
  tokenHash    String   @unique
  userId       String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastSeenAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ProviderConfig {
  id                  String   @id @default(cuid())
  userId              String   @unique
  activeProvider      String?
  openaiKeyEncrypted  String?
  openaiBaseUrl       String?
  openaiModel         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlatformProviderConfig {
  id                 String   @id @default("platform")
  openaiKeyEncrypted String?
  openaiBaseUrl      String?
  openaiModel        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AppSetting {
  id                 String   @id @default("settings")
  registrationOpen   Boolean  @default(false)
  dailyPlatformQuota Int      @default(20)
  siteTitle          String?
  faviconUrl         String?
  logoUrl            String?
  imageQueueMode     String?
  imageJobConcurrency Int?
  imageJobUserConcurrency Int?
  imageQueueRedisUrlEncrypted String?
  imageQueuePrefix   String?
  imageWorkerConcurrency Int?
  imageQueueAttempts Int?
  imageQueueBackoffMs Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  adminUserId  String
  action       String
  targetType   String
  targetId     String?
  metadataJson String   @default("{}")
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([adminUserId, createdAt])
}

model ImageRecord {
  id             String   @id @default(cuid())
  userId         String
  provider       String
  model          String
  mode           String
  prompt         String
  filePath       String
  mimeType       String
  thumbnailPath  String?
  thumbnailMimeType String?
  size           String?
  aspectRatio    String?
  quality        String?
  inputFidelity  String?
  sourceImageIds String   @default("[]")
  uploadImageIds String   @default("[]")
  parentId       String?
  batchId        String?
  batchItemId    String?
  projectId      String?
  tags           String   @default("[]")
  providerMeta   String?
  archivedAt     DateTime?
  deletedAt      DateTime?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch ImageBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  project ImageProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt, id])
  @@index([userId, batchId])
  @@index([userId, projectId])
  @@index([userId, deletedAt, createdAt])
  @@index([provider])
  @@index([model])
}

model ImageJob {
  id          String    @id @default(cuid())
  userId      String
  status      String    @default("pending")
  provider    String
  model       String
  mode        String
  prompt      String
  requestJson String
  batchId     String?
  batchItemId String?
  resultId    String?
  error       String?
  failureCode String?
  failureCategory String?
  retryCount  Int       @default(0)
  adminActionBy String?
  adminActionAt DateTime?
  lockedBy    String?
  lockedAt    DateTime?
  heartbeatAt DateTime?
  startedAt   DateTime?
  finishedAt  DateTime?
  queueWaitMs Int?
  executionMs Int?
  upstreamMs  Int?
  fileSaveMs  Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch ImageBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([userId, batchId])
  @@index([failureCategory, updatedAt])
  @@index([batchItemId])
  @@index([status, createdAt])
  @@index([status, lockedAt])
  @@index([status, heartbeatAt])
  @@index([lockedBy, status])
}

model ImageBatch {
  id           String    @id @default(cuid())
  userId       String
  projectId    String?
  name         String
  provider     String
  model        String
  mode         String
  status       String    @default("queued")
  totalCount   Int
  successCount Int       @default(0)
  failedCount  Int       @default(0)
  promptFormat String    @default("blocks")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  finishedAt   DateTime?
  archivedAt   DateTime?

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  project ImageProject?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  items   ImageBatchItem[]
  jobs    ImageJob[]
  records ImageRecord[]

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([userId, projectId])
}

model ImageBatchItem {
  id         String    @id @default(cuid())
  batchId    String
  userId     String
  itemIndex  Int
  provider   String
  model      String
  mode       String
  prompt     String
  status     String    @default("queued")
  jobId      String?
  resultId   String?
  error      String?
  retryCount Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  startedAt  DateTime?
  finishedAt DateTime?

  batch ImageBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([batchId, itemIndex])
  @@index([userId, status])
  @@index([batchId, status])
  @@index([jobId])
}

model ImageProject {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String?
  archivedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  images ImageRecord[]
  batches ImageBatch[]
  templates PromptTemplate[]

  @@unique([userId, name])
  @@index([userId, createdAt])
  @@index([userId, archivedAt, updatedAt])
}

model PromptTemplate {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  title     String
  description String?
  category  String   @default("Default")
  mode      String   @default("universal")
  content   String
  tags      String   @default("[]")
  defaultsJson String?
  archivedAt DateTime?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  project ImageProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, mode])
  @@index([userId, projectId])
  @@index([userId, deletedAt, updatedAt])
}

model StoredImage {
  id        String   @id @default(cuid())
  userId    String
  kind      String
  filePath  String
  mimeType  String
  filename  String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model UsageDaily {
  id           String   @id @default(cuid())
  userId       String
  date         String
  platformUses Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}
