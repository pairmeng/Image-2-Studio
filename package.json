{
  "name": "image-2-studio",
  "version": "1.2.18",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "tsc -p tsconfig.worker.json",
    "db:sqlite": "powershell -ExecutionPolicy Bypass -File scripts/use-sqlite-prisma.ps1",
    "db:postgres": "powershell -ExecutionPolicy Bypass -File scripts/use-postgres-prisma.ps1",
    "db:generate": "prisma generate --schema prisma/schema.active.prisma",
    "db:migrate": "prisma migrate deploy --schema prisma/schema.active.prisma",
    "db:push": "powershell -ExecutionPolicy Bypass -File scripts/db-push-sqlite.ps1",
    "db:validate": "powershell -ExecutionPolicy Bypass -File scripts/db-validate-sqlite.ps1",
    "start": "next start",
    "test:jobs": "tsc -p tsconfig.test.json && node --test .test-dist/tests/job-monitor.test.js .test-dist/tests/image-job-scheduling.test.js .test-dist/tests/image-job-state.test.js .test-dist/tests/batch-timeout.test.js .test-dist/tests/image-job-runner.test.js .test-dist/tests/history-records.test.js .test-dist/tests/image-worker-startup.test.js .test-dist/tests/batch-start.test.js .test-dist/tests/version.test.js .test-dist/tests/deployment-config.test.js .test-dist/tests/responses.test.js",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "publish:dev": "powershell -ExecutionPolicy Bypass -File scripts/publish-image.ps1 -Dev -Verify -RequireClean",
    "verify": "pnpm run db:validate && pnpm run lint && pnpm run test:jobs && pnpm run build:worker && pnpm run build"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.34.2",
    "ioredis": "^5.4.2",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "openai": "^4.77.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@playwright/test": "^1.59.1",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "prisma": "^6.19.0",
    "typescript": "^5.7.2"
  }
}
