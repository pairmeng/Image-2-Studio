{
  "name": "image-2-studio",
  "version": "1.2.18",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "tsc -p tsconfig.worker.json",
    "db:sqlite": "powershell -ExecutionPolicy Bypass -File scripts/use-sqlite-prisma.ps1",
    "db:postgres": "powershell -ExecutionPolicy Bypass -File scripts/use-postgres-prisma.ps1",
    "db:generate": "prisma generate --schema prisma/schema.active.prisma",
    "db:migrate": "prisma migrate deploy --schema prisma/schema.active.prisma",
    "db:push": "powershell -ExecutionPolicy Bypass -File scripts/db-push-sqlite.ps1",
    "db:validate": "node scripts/db-validate-sqlite.mjs",
    "start": "next start",
    "test:jobs": "tsc -p tsconfig.test.json && node --test .test-dist/tests/job-monitor.test.js .test-dist/tests/job-monitor-summary.test.js .test-dist/tests/image-job-scheduling.test.js .test-dist/tests/image-job-state.test.js .test-dist/tests/batch-timeout.test.js .test-dist/tests/image-job-runner.test.js .test-dist/tests/history-records.test.js .test-dist/tests/admin-images.test.js .test-dist/tests/admin-usage.test.js .test-dist/tests/history-action-helpers.test.js .test-dist/tests/history-filtering.test.js .test-dist/tests/history-selection-context.test.js .test-dist/tests/image-links.test.js .test-dist/tests/provider-model-context.test.js .test-dist/tests/provider-config.test.js .test-dist/tests/reference-files.test.js .test-dist/tests/selected-record-context.test.js .test-dist/tests/session-expiry.test.js .test-dist/tests/image-worker-startup.test.js .test-dist/tests/image-queue-settings.test.js .test-dist/tests/security.test.js .test-dist/tests/batch-start.test.js .test-dist/tests/version.test.js .test-dist/tests/deployment-config.test.js .test-dist/tests/responses.test.js .test-dist/tests/image-response.test.js .test-dist/tests/password-policy.test.js .test-dist/tests/api-client.test.js .test-dist/tests/batch-input-summary.test.js .test-dist/tests/batch-progress.test.js .test-dist/tests/batch-prompts.test.js .test-dist/tests/gallery-derived-lists.test.js .test-dist/tests/generation-api.test.js .test-dist/tests/generation-job-tracking.test.js .test-dist/tests/generation-options.test.js .test-dist/tests/generation-run-builders.test.js .test-dist/tests/generation-validation.test.js .test-dist/tests/model-defaults.test.js .test-dist/tests/template-action-helpers.test.js .test-dist/tests/studio-view-model.test.js",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "publish:dev": "powershell -ExecutionPolicy Bypass -File scripts/publish-dev-action.ps1 -Verify -RequireClean",
    "publish:dev:docker": "powershell -ExecutionPolicy Bypass -File scripts/publish-image.ps1 -Dev -Verify -RequireClean",
    "verify": "pnpm run db:validate && pnpm run lint && pnpm run test:jobs && pnpm run build:worker && pnpm run build"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.34.2",
    "ioredis": "^5.4.2",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "openai": "^4.77.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@playwright/test": "^1.59.1",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "prisma": "^6.19.0",
    "typescript": "^5.7.2"
  }
}
