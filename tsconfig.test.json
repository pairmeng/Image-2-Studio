{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "declaration": false,
    "incremental": false,
    "isolatedModules": false,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [
    "src/lib/batch-start.ts",
    "src/lib/batch-timeout.ts",
    "src/lib/history-records.ts",
    "src/lib/admin-images.ts",
    "src/lib/admin-usage.ts",
    "src/lib/image-job-scheduling.ts",
    "src/lib/image-job-runner.ts",
    "src/lib/image-job-state.ts",
    "src/lib/image-worker-startup.ts",
    "src/lib/job-monitor.ts",
    "src/lib/server/errors.ts",
    "src/lib/server/image-response.ts",
    "src/lib/server/password-policy.ts",
    "src/lib/server/responses.ts",
    "src/lib/types.ts",
    "src/components/studio/utils/api-client.ts",
    "src/components/studio/utils/batch-input-summary.ts",
    "src/components/studio/utils/batch-progress.ts",
    "src/components/studio/utils/gallery-derived-lists.ts",
    "src/components/studio/utils/generation-api.ts",
    "src/components/studio/utils/generation-job-tracking.ts",
    "src/components/studio/utils/generation-run-builders.ts",
    "src/components/studio/utils/generation-validation.ts",
    "src/components/studio/utils/history-action-helpers.ts",
    "src/components/studio/utils/history-filtering.ts",
    "src/components/studio/utils/history-selection-context.ts",
    "src/components/studio/utils/image-links.ts",
    "src/components/studio/utils/job-monitor-summary.ts",
    "src/components/studio/utils/provider-model-context.ts",
    "src/components/studio/utils/reference-files.ts",
    "src/components/studio/utils/selected-record-context.ts",
    "src/components/studio/utils/session-expiry.ts",
    "src/components/studio/utils/template-action-helpers.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".test-dist"
  ]
}
